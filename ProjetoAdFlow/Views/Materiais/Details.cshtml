@model AdFlow.Models.Material

@{
    ViewData["Title"] = "Detalhes Materiais";
}

<h1>Detalhes</h1>
<br>
<div>
    <h4>Material</h4>

    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CaminhoArquivo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CaminhoArquivo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataCriacao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataCriacao)
        </dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("Administrador") || User.IsInRole("Redator") || User.IsInRole("Designer"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Editar</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Retornar à Lista</a>
</div>
