@model AdFlow.Models.FluxoCampanha

@{
    ViewData["Title"] = "Detalhes Fluxos Campanha";
}

<h1>Detalhes</h1>
<br>
<div>
    <h4>Fluxo Campanha</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descricao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descricao)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DataCriacao)
        </dt>
        <dd class = "col-sm-10">
