@model AdFlow.Models.Identity.ApplicationUser

@{
    ViewData["Title"] = "Editar Funcionário";
}

<h1>Editar Funcionário</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Nome"></label>
                <input asp-for="Nome" class="form-control" />
            </div>
            <br>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
            </div>
            <br>
            <div class="form-group">
                <label asp-for="NIF"></label>
                <input asp-for="NIF" class="form-control" />
            </div>
            <br>
            <div class="form-group">
                <label asp-for="Endereco">Endereço</label>
                <input asp-for="Endereco" class="form-control" />
            </div>
            <br>
            <div class="form-group">
                <label>Cargo</label>
                <select name="role" class="form-control" asp-items="ViewBag.Roles">
                </select>
            </div>

            <br />
            <br>
            <button type="submit" class="btn btn-primary">
                Guardar
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancelar
            </a>
        </form>
    </div>
</div>

