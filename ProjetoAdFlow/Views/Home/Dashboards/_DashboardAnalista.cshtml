<h4>📊 Gestão de Campanhas</h4>

<div class="row">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>Criar Campanha</h5>
                <a asp-controller="Campanhas" asp-action="Create" class="btn btn-success">Nova</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>Ver Campanhas</h5>
                <a asp-controller="Campanhas" asp-action="Index" class="btn btn-primary">Aceder</a>
            </div>
        </div>
    </div>

</div>
